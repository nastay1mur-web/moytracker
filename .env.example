# Telegram Bot
# Получить у @BotFather: /newbot → скопировать токен
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Backend
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/habit_tracker

# Случайная строка для подписи JWT / сессий (минимум 32 символа)
# Сгенерировать: openssl rand -hex 32
SECRET_KEY=your-secret-key-minimum-32-characters-long

# URL фронтенда Mini App (нужен боту для кнопки "Открыть трекер")
# Должен быть HTTPS — Telegram не принимает HTTP
WEBAPP_URL=https://your-app.vercel.app

# Окружение: development | production
ENV=development

# Порт бэкенда
PORT=8000
