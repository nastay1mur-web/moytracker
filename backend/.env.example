# ──────────────────────────────────────────────
# Скопируй этот файл в .env и заполни значения
# cp .env.example .env
# ──────────────────────────────────────────────

# Telegram Bot (получить у @BotFather)
BOT_TOKEN=

# База данных Supabase
# Найти: Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Платёжный провайдер (получить у @BotFather → Payments → ЮKassa Test)
# Для теста оставь пустым — оплата будет работать в тестовом режиме
PAYMENT_PROVIDER_TOKEN=

# URL фронтенда (уже задеплоен на Vercel)
WEBAPP_URL=https://tg-app-green.vercel.app

# Среда запуска: development | production
NODE_ENV=development

# Порт сервера
PORT=8000
